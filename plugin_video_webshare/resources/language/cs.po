#: plugin_video_webshare/webshare.py:149
msgid "Failed to get user informations"
msgstr "Nepodařilo se získat informcace o uživateli"

#: plugin_video_webshare/webshare.py:214
msgid "Wrong webshare login data provided"
msgstr "Chybné přihlašovací údaje pro Webshare"

#: plugin_video_webshare/webshare.py:217
msgid "Webshare subscription expired. Only very low quality videos will play and seeking forward/backward will not work at all."
msgstr "Webshare předplatné vypršelo. Přehrávání bude fungovat jen u videí s velmi nízkou kvalitou a přetáčení vpřed/vzad nebude fungovat vůbec."

#: plugin_video_webshare/webshare.py:219
msgid "No webshare login data provided. Only very low quality videos will play and seeking forward/backward will not work at all."
msgstr "Nebyly zadány přihlašovací údaje pro Webshare. Přehrávat se budou pouze videa ve velmi nízké kvalitě a posun vpřed/vzad nebude fungovat vůbec."

#: plugin_video_webshare/webshare.py:234
msgid "File is password protected"
msgstr "Soubor je chráněn heslem"

#: plugin_video_webshare/webshare.py:240
msgid "Failed to resolve file"
msgstr "Nepodařilo se získat adresu souboru"

#: plugin_video_webshare/provider.py:35
#, python-brace-format
msgid ""
"Login to premium account failed: {reason}\n"
"Continuing with free account."
msgstr ""
"Přihlášení do premium konta selhalo: {reason}\n"
"Pokračuji s free kontem."

#: plugin_video_webshare/provider.py:54
msgid "Remove from watched"
msgstr "Odebrat ze sledovaných"

#: plugin_video_webshare/provider.py:152
msgid "Item were removed. Change will be efective after next addon start."
msgstr "Položka byla odstraněna. Změna bude účinná po příštím spuštění addonu."

msgid "Login name"
msgstr "Přihlašovací jméno"

msgid "Login password"
msgstr "Přihlašovací heslo"

msgid "Max watched items"
msgstr "Maximální počet viděných položek"

msgid "Number of remembered searches"
msgstr "Počet uložených vyhledávání"

msgid "Search category"
msgstr "Kategorie vyhledávání"

msgid "Cleanup watched items from webshare history"
msgstr "Vymaž sledované položky z webshare historie"

msgid "Remove duplicated items"
msgstr "Odstranit duplicitní položky"
