<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<settings>

	<setting label="Server (IP/domain or URL)" type="text" id="host" default="127.0.0.1"/>
	<setting label="Port" type="text" id="port" default="9981"/>
	<setting label="Use HTTPS" type="bool" id="use_https" default="false"/>
	<setting label="Username" type="text" id="username" default=""/>
	<setting label="Password" type="password" id="password" default=""/>
	<setting label="HTTP authentication" type="keyenum" id="http_auth_mode"
			 values="auto;Auto|digest;Digest|basic;Basic|none;None" default="auto"/>
	<setting label="Use ticket URL (recommended for Digest)" type="bool" id="use_ticket_url" default="true"/>
	<setting label="TVH stream profile" type="keyenum" id="profile"
			 values="pass;pass|mpegts;mpegts|matroska;matroska|htsp;htsp|webtv-h264-aac-matroska;webtv-h264-aac-matroska|webtv-h264-aac-mpegts;webtv-h264-aac-mpegts" default="pass"/>
	<setting label="Timeout (seconds)" type="text" id="loading_timeout" default="15"/>

	<category label="Userbouquet">
		<setting label="Automatically export channel list as userbouquet"
				 id="enable_userbouquet" type="bool" default="false" />

		<setting label="Auto-refresh bouquet interval"
				 id="bouquet_refresh_interval" type="keyenum"
				 values="0;Disabled|14400;4 hours|28800;8 hours|57600;16 hours|86400;24 hours|172800;2 days|604800;7 days" default="86400"/>

		<setting label="Allow creating userbouquet for radios"
				 id="enable_userbouquet_radio" type="bool" default="false" />

		<setting label="Add category names to userbouquet"
				 id="userbouquet_categories" type="bool" default="false" />

		<setting label="Custom bouquet display name (TV)"
				 id="userbouquet_custom_name_tv" type="text" default="Tvheadend TV" />

		<setting label="Custom bouquet display name (Radio)"
				 id="userbouquet_custom_name_radio" type="text" default="Tvheadend Radio" />

		<!-- FIX 0.48e: EPG injection priamo do Enigma2 eEPGCache (bez epgimport).
		     Hodnota 0 = úplne vypnuté, inak interval medzi auto-injekciami.
		     Pri každom bouquet refresh-i sa injekcia spustí aj mimo intervalu. -->
		<setting label="Auto-inject EPG into Enigma2 (no epgimport plugin needed)"
				 id="tvh_epg_inject_interval" type="keyenum"
				 values="0;Disabled|14400;4 hours|28800;8 hours|43200;12 hours|57600;16 hours|86400;24 hours|172800;2 days|604800;7 days"
				 default="14400"/>

		<setting label="Automatically download picons when exporting userbouquet"
				 id="enable_picons" type="bool" default="false" />

		<setting label="For how many days to keep Enigma2 EPG history"
				 id="enigmaepg_days" type="enum" lvalues="1|2|3|4|5|6|7|14" default="7"/>

		<setting label="Player used for userbouquet"
				 id="player_name" type="enum"
				 lvalues="Default|gstplayer|exteplayer3" default="0"/>
	</category>

	<category label="External M3U">

		<setting label="Enable external M3U playlist source"
				 id="enable_m3u_source" type="bool" default="false"/>

		<setting label="M3U playlist URL"
				 id="m3u_url" type="text" default=""/>

		<setting label="XMLTV EPG URL (optional; leave empty to use TVH XMLTV)"
				 id="m3u_epg_url" type="text" default=""/>

		<setting label="Enrich M3U channels using TVH API (recommended for TVH playlists)"
				 id="m3u_enrich_from_tvh" type="bool" default="true"/>

		<setting label="Service type (1 = native DVB, supports DVB subtitles)"
				 id="m3u_service_type" type="keyenum"
				 values="1;Native DVB (DVB subs)|4097;Default player|5001;gstplayer|5002;exteplayer3"
				 default="1"/>

		<setting label="M3U bouquet display name"
				 id="m3u_bouquet_name" type="text" default="IPTV M3U"/>

		<!-- FIX 0.48f: m3u_bouquet_prefix setting odstránené - hardcoded
		     v m3u_bouquet.py:M3U_BOUQUET_PREFIX. Pre 100% userov bol
		     irelevantný (filename na disku, Enigma2 ho nezobrazuje). -->

		<setting label="Refresh interval"
				 id="m3u_refresh_interval" type="keyenum"
				 values="0;Disabled|14400;4 hours|28800;8 hours|57600;16 hours|86400;24 hours|172800;2 days|604800;7 days"
				 default="86400"/>

		<setting label="Download picons from tvg-logo URLs"
				 id="m3u_picons_from_logo" type="bool" default="true"/>

		<!-- FIX 0.48g: m3u_write_epgimport + m3u_inject_epg_to_enigma odstránené.
		     Nahradené samostatným EPG injection intervalom (analógia s TVH 0.48e).
		     Generation epgimport súborov (write_epgimport=true) je teraz vždy
		     vypnuté — direct injection robí to isté efektívnejšie. -->
		<setting label="Auto-inject EPG into Enigma2 (no epgimport plugin needed)"
				 id="m3u_epg_inject_interval" type="keyenum"
				 values="0;Disabled|14400;4 hours|28800;8 hours|43200;12 hours|57600;16 hours|86400;24 hours|172800;2 days|604800;7 days"
				 default="14400"/>

		<setting label="Use mapping override XML"
				 id="m3u_use_mapping" type="bool" default="false"/>

		<setting label="Mapping override file path"
				 id="m3u_mapping_file" type="text"
				 default="/etc/enigma2/m3u-sort-override.xml"/>

	</category>

	<category label="Archive">
		<setting label="Archive: max items from DVR" type="text" id="dvr_limit" default="0"/>
		<setting label="Archive: max number of days (0=no limit)" type="text" id="archive_days_limit" default="0"/>
	</category>

</settings>
