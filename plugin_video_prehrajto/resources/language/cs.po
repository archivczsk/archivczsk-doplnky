#: plugin_video_prehrajto/prehrajto.py:44
msgid "Unexpected return code from server"
msgstr "Neočekávaný návratový kód ze serveru"

#: plugin_video_prehrajto/provider.py:31
msgid "Login to premium account failed. Continuing with free account."
msgstr "Přihlášení do premium konta selhalo. Pokračuji s free kontem."

#: plugin_video_prehrajto/provider.py:82
msgid "Failed to find video stream. If this message appears on every video, then site was probably changed and addon needs to be updated. In that case report this info to addon author."
msgstr "Nepodařilo se najít video stream. Pokud se tato zpráva zobrazuje u každého videa, pak byl web pravděpodobně změněn a je třeba doplněk aktualizovat. V takovém případě nahlaste tuto informaci autorovi doplňku."

#: plugin_video_prehrajto/provider.py:86
msgid "Available subtitles"
msgstr "Dostupné titulky"

msgid "Login name"
msgstr "Přihlašovací jméno"

msgid "Login password"
msgstr "Přihlašovací heslo"

msgid "Max watched items"
msgstr "Maximální počet viděných položek"

msgid "Number of remembered searches"
msgstr "Počet uložených vyhledávání"

msgid "Enable subtitles support"
msgstr "Povolit podporu pro titulky"

msgid "Remove duplicated items"
msgstr "Odstranit duplicitní položky"

