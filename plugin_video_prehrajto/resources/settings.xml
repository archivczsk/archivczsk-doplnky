<?xml version="1.0" encoding="UTF-8"?>
<settings>
  <setting label="Login name" id="username" type="text" default=""/>
  <setting label="Login password" id="password" type="password" default=""/>
  <setting label="Max watched items" id="max_watched" type="number" default="10"/>
  <setting label="Number of remembered searches" id="keep-searches" type="labelenum" values="0|5|10|15|20|25|30|35|40|45|50" default="20"/>
  <setting label="Enable subtitles support" id="enable_subtitles" type="bool" default="true"/>
  <setting label="Remove duplicated items" id="remove_duplicated" type="bool" default="true"/>
</settings>
